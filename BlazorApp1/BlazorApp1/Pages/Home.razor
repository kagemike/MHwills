@page "/"

<PageTitle>魔物獵人隨機抽籤</PageTitle>

<div style="text-align:center; font-family: 'Microsoft JhengHei';">
    <h1>魔物獵人武器抽籤</h1>

    @if (!string.IsNullOrEmpty(currentImage))
    {
        <!-- 顯示圖片 -->
        <div style="margin: 20px;">
            <img src="images/@(currentImage).png" style="max-width:300px; border-radius:10px;" />
        </div>
        <!-- 顯示 TextBox (網頁標籤為 input) -->
        <input type="text" readonly value="@currentText" style="text-align:center; padding:5px; width:200px;" />
    }
    else
    {
        <div style="height:300px; line-height:300px; border:1px dashed #ccc; margin:20px;">
            點擊下方按鈕開始抽籤
        </div>
    }

    <br /><br />
    <button class="btn btn-primary" @onclick="Draw">隨機抽一張！</button>
</div>

@code {
    private string currentImage = "";
    private string currentText = "";

    // 你的武器清單
    private string[] weapons = { "Bow", "Dual Blades", "Great Sword", "Gunlance", "hammer", "Heavy Bowgun", "Hunting Horn", "Insect Glaive_1", "Lance", "Switch Axe", "Sword & Shield", "Long Sword", "Light Bowgun", "Charge Blade" };
    

    private void Draw()
    {
        Random rand = new Random();
        int index = rand.Next(weapons.Length);

        currentImage = weapons[index]; // 對應檔名

    }
}
